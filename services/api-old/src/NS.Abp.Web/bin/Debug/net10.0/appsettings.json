{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "SqlSugar": {
    "DefaultConnectionName": "Default",
    "ConnectionStrings": {
      "Default": "sqlsugar_default_connstring"
    },
    "DbTypes": {
      "Default": "sqlsugar_default_dbtype"
    }
  },
  "AliYunOptions": {
    "AccessKeyId": "",
    "AccessKeySecret": "",
    "EndPoint": "dysmsapi.aliyuncs.com",
    "Sms": {
      "SignName": "阿里云通信",
      "TemplateCode": "SMS_XXXXXXX"
    }
  },
  "SendCloudOptions": {
    "ApiUser": "",
    "ApiKey": "",
    "From": "noreply@claymo.cn"
  },
  "Redis": {
    "IsEnabled": true,
    "Configuration": "redis:6379",
    "JobDb": 1
  },
  "AbpDistributedCacheOptions": {
    "KeyPrefix": "ClayMo:"
  },
  "Authentication": {
    "Jwt": {
      "SigningKey": "DevSecretKeyAtLeast32CharactersLong!",
      "Issuer": "ClayMo",
      "Audience": "ClayMo",
      "AccessTokenLifetime": "00:30:00",
      "MinimumAccessTokenLifetime": "00:05:00"
    },
    "Token": {
      "MinimumRefreshTokenLength": 32,
      "UseSlidingExpiration": true,
      "Lifetime": "7.00:00:00",
      "Length": 64,
      "HashKey": "AnotherLongRandomSecretAtLeast32Chars!",
      "RefreshCookieName": "claymo.rt",
      "RefreshCookiePath": "/",
      "RefreshCookieSameSite": "None",
      "RefreshCookieSecurePolicy": "Always"
    },
    "Session": {
      "CookieName": "claymo.sid",
      "Ttl": "7.00:00:00",
      "CacheKeyPrefix": "sess:"
    },
    "Security": {},
    "Throttle": {
      "EnableRateLimit": true,
      "LoginWindow": "00:05:00",
      "LoginAttemptsThreshold": 10,
      "LockoutDuration": "00:10:00"
    }
  },
  "Hangfire": {
    "JobTimeoutHours": 1,
    "JobExpirationTimeoutHours": 24,
    "RedisPrefix": "ClayMo:HangfireJob:",
    "AllowMemoryStorage": false,
    "Dashboard": {
      "RequiredPermissionCode": "system.hangfire.dashboard",
      "AllowedCidrs": [],
      "AuthenticationScheme": null,
      "ReadOnly": false,
      "SkipAuthInDevelopment": false,
      "UserIdClaimTypes": ["sub", "user_id", "userid", "uid"]
    },
    "UnitOfWork": {
      "IsTransactional": true,
      "RequiresNew": true,
      "Timeout": null,
      "IsolationLevel": null
    }
  },
  "RateLimiting": {
    "IsEnabled": true,
    "PermitLimit": 1000,
    "WindowSeconds": 60,
    "SegmentsPerWindow": 6
  }
}


