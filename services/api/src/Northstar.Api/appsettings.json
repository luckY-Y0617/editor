{
  "ConnectionStrings": {
    "Northstar": "Host=localhost;Port=5432;Database=northstar;Username=postgres;Password=postgres"
  },
  "Database": {
    "Provider": "PostgreSQL",
    "CommandTimeoutSeconds": 30,
    "ApplyMigrationsOnStartup": true
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  },
  "Auth": {
    "Jwt": {
      "Issuer": "Northstar",
      "Audience": "Northstar",
      "AccessTokenMinutes": 15,
      "RefreshTokenDays": 14
    }
  },
  "Files": {
    "StorageProvider": "Local",
    "LocalRootPath": "var/files",
    "DefaultBucket": "northstar-local",
    "S3": {
      "Endpoint": "",
      "Region": "us-east-1",
      "AccessKey": "",
      "SecretKey": "",
      "ForcePathStyle": true,
      "UseHttp": false,
      "PresignedUploadMinutes": 15
    },
    "UploadSessionMinutes": 60,
    "MaxFileBytes": 52428800,
    "AllowedMimeTypes": [
      "image/png",
      "image/jpeg",
      "image/webp",
      "application/pdf",
      "text/plain"
    ]
  },
  "Permissions": {
    "ExpiryNotifications": {
      "Enabled": true,
      "ScanIntervalMinutes": 60,
      "ExpiringWindowHours": 24
    },
    "PublicShareLinks": {
      "Enabled": false,
      "ViewerOnly": true,
      "RequireExpiry": true,
      "MaxExpiryDays": 30,
      "MaxExpiryDaysForLibrary": 30,
      "RequirePassword": false,
      "RequirePasswordForCollection": true,
      "RequirePasswordForLibrary": true,
      "DefaultDisableDownload": true,
      "DefaultDisablePrint": false,
      "DefaultDisableCopy": false,
      "DefaultWatermarkEnabled": false,
      "RequireWatermarkForCollection": false,
      "RequireWatermarkForLibrary": false,
      "DisallowDownloadForPublicLinks": true,
      "AllowDocumentScope": true,
      "AllowCollectionScope": true,
      "AllowLibraryScope": false,
      "AllowNoExpiry": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
